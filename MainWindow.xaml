<Window x:Class="demo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:demo"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800" MinWidth="800"
        MinHeight="450" SizeToContent="Manual" ResizeMode="CanMinimize">
    <Grid>

        <!--This grid is responsible for the start page-->
        <Grid x:Name="start_grid" Visibility="Visible"
              Background="#FFF0F6">

            <!-- CyberBabe Logo -->
            <Image 
                Source="/cyberbabe_logo.png"
                Height="250"
                Width="300"
                Margin="0,0,0,200"
                   />
            <!-- welcome message-->
            <TextBlock
                Text="Welcome to CyberBabe"
                Height="50"
                Width="300"
                TextAlignment="Center"
                Margin="0,100,0,0"
                FontFamily="Arial Rounded MT Bold"
                />

            <!-- start cyberbabe button-->
            <Button 
                Background="#FFA2B9"
                Height="50"
                Width="300"
                Margin="0,200,0,0"
                Content="Start CyberBabe"
                Click="proceed"
                />

        </Grid>

        <!--Username Grid-->
        <Grid x:Name="username_grid" 
              Visibility="Hidden"
              Background="#FFF0F6">

            <Border Width="400"
            Padding="30"
            Background="White"
            CornerRadius="15"
            BorderBrush="#F3C4DA"
            BorderThickness="1"
            HorizontalAlignment="Center"
            VerticalAlignment="Center">

                <StackPanel HorizontalAlignment="Center">

                    <!-- Logo -->
                    <Image Source="/cyberbabe_logo.png"
                   Height="180"
                   Width="220"
                   Margin="0,0,0,20"/>

                    <!-- Welcome Text -->
                    <TextBlock Text="Welcome to CyberBabe"
                       FontSize="24"
                       FontWeight="Bold"
                       Foreground="#D63384"
                       HorizontalAlignment="Center"
                       Margin="0,0,0,10"/>

                    <!-- Instruction -->
                    <TextBlock Text="Please enter your username to continue"
                       FontSize="14"
                       Foreground="#8A4B6B"
                       TextAlignment="Center"
                       Margin="0,0,0,20"/>


                    <TextBlock Text="Username must not contain numbers or symbols"
                               TextAlignment="Center"
                               Foreground="Red"
                        />

                    <TextBox x:Name="users_input"
                     Width="300"
                     Height="45"
                     FontSize="14"
                     Padding="10"
                     BorderBrush="#E649A1"/>

                    <!-- button to submit name-->
                    <Button Content="Submit Username"
                     Width="300"
                     Height="45"
                     Background="#E649A1"
                     Foreground="White"
                     FontWeight="Bold"
                     Click="submit_name"
                    />


                </StackPanel>
            </Border>
        </Grid>

        <!--This grid deals with the menu where the user has to pick-->

        <Grid x:Name="MainPage" 
         Height="450"
         Width="800"
         Visibility="Hidden"
         Background=" #FFF1F4 ">

            <!-- Right-side vertical menu bar -->
            <Grid Margin="595,0,0,0"
            Background="#FFF1F4"
            Width="215"
                 >

                <!-- StackPanel that has the menu buttons -->
                <StackPanel Grid.Column="0"
                      Background="#FFF1F4" 
                      Width="170"
                      Margin="0,0,13,0"
                      >
                    

                    <TextBlock Text="Menu" 
                     TextAlignment="Center"
                     FontSize="18" 
                     FontWeight="Bold" 
                     Margin="0,0,0,20"/>
                   

                    <!-- Menu buttons -->
                    <Button Content="Chats"  Background="#FFD1DC" FontWeight="Bold" Margin="0,5,0,0" Height="40" Click="chatting"/>
                    <Button Content="Tasks Reminders" Background="#FFA2B9" FontWeight="Bold"  Margin="0,30,0,0" Height="50" Click="reminders"/>
                    <Button Content="Activity Log" Background=" #F83B72" FontWeight="Bold" Margin="0,30,0,0" Height="50" Click="activity"/>
                    <Button Content="Game" Background=" #E5195E " FontWeight="Bold" Margin="0,30,0,0" Height="50" Click="game"/>
                    <Button Content="Exit" Background=" #C20E4F " FontWeight="Bold" Margin="0,30,0,0" Height="50" Click="exit"/>
                </StackPanel>
            </Grid>




            <!-- Chat page - default visible inside main app -->
            <Grid Margin="0,0,205,0"
            x:Name="chatbot_page"
            Visibility="Visible">


                <!-- Heading -->
                <TextBlock x:Name="Heading"
               Text="CyberBabe ChatBot"
               FontSize="28"
               FontWeight="Bold"
               Foreground="#D63384"
               HorizontalAlignment="Center"
               Margin="0,-8,0,28"/>


                <!-- ListView to show chat messages -->
                <ListView Margin="8,30,10,101"
                    x:Name="Conversation" />

                <!-- TextBox where user's questions -->
                <TextBox Margin="8,363,170,27"
                   x:Name="question" />

                <!-- Button that submits the user's question -->
                <Button
                  Content="Send"
                  Height="40"
                  Background="#E649A1"
                  Foreground="White"
                  Click="send"
                  Margin="430,363,84,31" />

                <!-- Clear Button -->
                <Button
                Content="Clear"
                Height="40"
                Background="#DC2626"
                Foreground="White"
                FontWeight="Bold" Margin="516,363,0,31"
                Click="Clear"
                    />

            </Grid>


            <!-- Reminders page -->
            <Grid Margin="0,0,205,0"
            x:Name="reminder_page"
            Visibility="Hidden">

                <!-- ListView showing reminders, double-click to mark done or delete -->
                <ListView Margin="20,10,27,87"
                    MouseDoubleClick="remind_append_MouseDoubleClick"
                    x:Name="view_tasks" />

                <!-- Instructions for reminders page -->
                <TextBlock Text="All the task will be listed above with their status of done or due, if not then double click to mark done and double click to delete or remove once done."
                     TextAlignment="Center"
                     Margin="20,368,14,36"
                     TextWrapping="Wrap"
                     Foreground="Red" />
            </Grid>



            <!-- History page -->
            <Grid Margin="0,0,205,0"
            x:Name="history_page"
            Visibility="Hidden">

                <!-- ListView to show user's interest history -->
                <ListView Margin="20,10,27,87"
                    MouseDoubleClick="remind_append_MouseDoubleClick"
                    x:Name="history_append" />

                <!-- Instructions for history page -->
                <TextBlock Text="If no history listed then try to add some from the chats , by saying 'im interest then mention your interest there, thank you.'"
                     TextAlignment="Center"
                     Margin="20,368,14,36"
                     TextWrapping="Wrap"
                     Foreground="Red" />
            </Grid>

            <!-- Activity log page -->
            <Grid Margin="0,0,205,0"
            x:Name="log_page"
            Visibility="Hidden">

                <!-- ListView showing all app activities -->
                <ListView Margin="20,10,27,87"
                    MouseDoubleClick="remind_append_MouseDoubleClick"
                    x:Name="log_append" />

                <!-- Instructions for activity log -->
                <TextBlock Text="All the activities that happens here on the app will be showed here based on what you do or doing."
                     TextAlignment="Center"
                     Margin="20,368,14,36"
                     TextWrapping="Wrap"
                     Foreground="Red" />
            </Grid>

            <!-- Game page for quiz -->
            <Grid Margin="0,0,205,0"
            x:Name="game_page"
            Visibility="Hidden">

                <!-- Quiz game content -->
                <Grid Height="390px"
                x:Name="Game_quiz_page"
                Visibility="Visible"
                Margin="10,30,10,30">

                    <!-- Question text -->
                    <TextBlock Height="50px"
                         Width="300px"
                         Text="Question" 
                         Foreground="SkyBlue" 
                         TextAlignment="Center"
                         FontSize="20px"
                         x:Name="question_asked"
                         Margin="0,0,0,210" />

                    <!-- Four option buttons for answers -->
                    <Button Height="40px"
                      Width="300px"
                      Background="Gray"
                      Content=""
                      Foreground="white"
                      FontSize="10px"
                      Margin="0,0,330,120"
                      x:Name="optionButtonOne"
                      Click="optionSelected" />

                    <Button Height="40px"
                      Width="300px"
                      Background="Gray"
                      Content=""
                      Foreground="white"
                      FontSize="10px"
                      Margin="330,0,0,120"
                      x:Name="optionButtonTwo"
                      Click="optionSelected" />

                    <Button Height="40px"
                      Width="300px"
                      Background="Gray"
                      Content=""
                      Foreground="white"
                      FontSize="10px"
                      Margin="0,0,330,0"
                      x:Name="optionButtonThree"
                      Click="optionSelected" />

                    <Button Height="40px"
                      Width="300px"
                      Background="Gray"
                      Content=""
                      Foreground="white"
                      FontSize="10px"
                      Margin="330,0,0,0"
                      x:Name="optionButtonFour"
                      Click="optionSelected" />

                    <!-- Button to submit the answer -->
                    <Button Height="40px"
                      Width="100px"
                      Background="Red"
                      Content="Answer"
                      Foreground="white" 
                      HorizontalContentAlignment="Center"
                      Margin="0,140,0,0"
                      Click="answerButton" />

                    <!-- Display for current score -->
                    <TextBlock Height="60px"
                         Width="100px"
                         Text="Score" 
                         Foreground="Gray" 
                         TextAlignment="Center"
                         FontSize="20px"
                         Margin="-2,6,477,324"
                         x:Name="score_count" />
                </Grid>
            </Grid>
        </Grid>
        <!-- End of main cover grid -->

    </Grid>
</Window>